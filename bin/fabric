#!/usr/bin/env bash
# fabric — operate the agent-fabric: one canonical hub for AI agent skills,
# rules, and memory, symlinked into every agent harness on this machine.
#
# macOS only (BSD userland; tested on Apple Silicon, macOS 13+ for readlink -f).

set -uo pipefail

FABRIC_HOME="${FABRIC_HOME:-$HOME/.agent-fabric}"
BACKUP_DIR="${FABRIC_HOME}/.backups/$(date +%Y-%m-%d)"
CANONICAL="${FABRIC_HOME}/AGENTS.md"
SKILLS_DIR="${FABRIC_HOME}/skills"
DRY_RUN=0

RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[0;33m'; BLUE=$'\033[1;34m'; NC=$'\033[0m'

log()  { printf '%s[fabric]%s %s\n' "$BLUE" "$NC" "$*"; }
ok()   { printf '%s[ok]%s %s\n' "$GREEN" "$NC" "$*"; }
warn() { printf '%s[warn]%s %s\n' "$YELLOW" "$NC" "$*" >&2; }
fail_msg() { printf '%s[FAIL]%s %s\n' "$RED" "$NC" "$*"; }
pass_msg() { printf '%s[PASS]%s %s\n' "$GREEN" "$NC" "$*"; }
info_msg() { printf '%s[info]%s %s\n' "$YELLOW" "$NC" "$*"; }

usage() {
  cat <<EOF
fabric — one canonical hub for AI agent skills, rules, and memory.

Commands:
  fabric sync [--dry-run]   Wire instruction files + fan out skills to detected harnesses.
                            --dry-run prints what would change without writing.
  fabric verify             Assert wiring topology + skill integrity; exit 1 on drift.
  fabric doctor             Effective-loading probes: does each harness actually resolve
                            the canonical content (not just have a symlink)? Exit 1 on failure.
  fabric status [--json]    Show detected harnesses, strategies, wiring state, skill count.
                            --json emits machine-readable output.
  fabric add-skill <name>   Scaffold a new skill in the hub and fan it out.
  fabric adopt <dir>        Move an existing skill dir into the hub (symlink left behind).
  fabric help               This help.

Design rules: the hub is the single source of truth; harnesses get SYMLINKS, never
copies; skill fanout is additive (existing real dirs are never replaced); anything
the fabric replaces is backed up to \$FABRIC_HOME/.backups/<date>/ first.
EOF
}

# ── Harness registry ─────────────────────────────────────────────────────────
# One record per harness. Fields (|-separated):
#   name | detect_dir | instruction_path | instruction_strategy | skills_dir | skills_strategy | cli | note
#
# instruction_strategy:
#   symlink  fabric manages a symlink at instruction_path -> canonical AGENTS.md
#   manual   cannot be wired by file (e.g. Warp global Rules live in cloud settings);
#            reported honestly instead of asserted
# skills_strategy:
#   additive fabric links hub skills into skills_dir without replacing existing entries
#   none     harness has no (usable) skills dir; it may still see ~/.agents/skills
# cli: binary name for presence probes in `fabric doctor` (may be empty)
registry() {
  cat <<EOF
generic|$HOME|$HOME/AGENTS.md|symlink|$HOME/.agents/skills|additive||AGENTS.md convention + shared skills root (read by Warp and others)
claude|$HOME/.claude|$HOME/.claude/CLAUDE.md|symlink|$HOME/.claude/skills|additive|claude|Claude Code
codex|$HOME/.codex|$HOME/.codex/AGENTS.md|symlink|$HOME/.codex/skills|additive|codex|Codex CLI
warp|$HOME/.warp|$HOME/.warp/AGENTS.md|manual||none||Warp global Rules are cloud-managed (Settings -> Rules); skills discovered via ~/.agents/skills
cursor|$HOME/.cursor|$HOME/.cursor/AGENTS.md|symlink||none|cursor|Cursor (skills via ~/.agents/skills)
gemini|$HOME/.gemini|$HOME/.gemini/GEMINI.md|symlink||none|gemini|Gemini CLI (no skills system)
grok|$HOME/.grok|$HOME/.grok/AGENTS.md|symlink|$HOME/.grok/skills|additive|grok|Grok CLI (keeps xAI bundled skills)
opencode|$HOME/.config/opencode|$HOME/.config/opencode/AGENTS.md|symlink|$HOME/.config/opencode/skills|additive|opencode|OpenCode
hermes|$HOME/.hermes|$HOME/.hermes/memories/AGENTS.md|symlink|$HOME/.hermes/skills|additive|hermes|Hermes (only AGENTS.md is symlink-safe in memories/)
EOF
}

# ── Helpers ──────────────────────────────────────────────────────────────────
backup_if_real() {
  local path="$1"
  if [[ -e "$path" && ! -L "$path" ]]; then
    if [[ "$DRY_RUN" == "1" ]]; then
      log "[dry-run] would back up $path -> $BACKUP_DIR/"
      return 0
    fi
    mkdir -p "$BACKUP_DIR"
    local dest="${BACKUP_DIR}/${path//\//_}"
    cp -R "$path" "$dest" 2>/dev/null || true
    log "backed up $path -> $dest"
  fi
}

link_replace() {
  local source="$1" target="$2"
  [[ -e "$source" ]] || { warn "skip: $source does not exist"; return 0; }
  if [[ -L "$target" && "$(readlink "$target")" == "$source" ]]; then
    return 0  # already correct
  fi
  if [[ "$DRY_RUN" == "1" ]]; then
    backup_if_real "$target"
    log "[dry-run] would link $target -> $source"
    return 0
  fi
  mkdir -p "$(dirname "$target")"
  if [[ -L "$target" ]]; then
    rm "$target"
  elif [[ -e "$target" ]]; then
    backup_if_real "$target"
    rm -rf "$target"
  fi
  ln -s "$source" "$target"
  ok "linked $target -> $source"
}

link_additive() {
  local source="$1" target="$2"
  [[ -e "$source" ]] || return 0
  [[ -e "$target" || -L "$target" ]] && return 0
  if [[ "$DRY_RUN" == "1" ]]; then
    log "[dry-run] would link (additive) $target -> $source"
    return 0
  fi
  mkdir -p "$(dirname "$target")"
  ln -s "$source" "$target"
  ok "linked (additive) $target -> $source"
}

json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

instr_state() {
  # echo one of: wired | conflict | missing | manual
  local instr="$1" strategy="$2"
  if [[ "$strategy" == "manual" ]]; then echo "manual"; return; fi
  if [[ -L "$instr" && "$(readlink "$instr")" == "$CANONICAL" ]]; then echo "wired"
  elif [[ -e "$instr" ]]; then echo "conflict"
  else echo "missing"
  fi
}

# ── sync ─────────────────────────────────────────────────────────────────────
cmd_sync() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) DRY_RUN=1 ;;
      *) fail_msg "unknown sync option: $1"; exit 1 ;;
    esac
    shift
  done
  [[ -d "$FABRIC_HOME" ]] || { fail_msg "hub $FABRIC_HOME missing — run install.sh first"; exit 1; }
  [[ -f "$CANONICAL" ]] || { fail_msg "$CANONICAL missing — run install.sh first"; exit 1; }

  [[ "$DRY_RUN" == "1" ]] && log "DRY RUN — no changes will be written"
  log "wiring instruction files"
  local name detect instr istrat sdir sstrat cli note skill sname
  while IFS='|' read -r name detect instr istrat sdir sstrat cli note; do
    [[ -n "$name" && -d "$detect" ]] || continue
    case "$istrat" in
      symlink) link_replace "$CANONICAL" "$instr" ;;
      manual)  info_msg "$name: $note" ;;
    esac
  done <<EOF
$(registry)
EOF

  log "fanning out skills (additive)"
  while IFS='|' read -r name detect instr istrat sdir sstrat cli note; do
    [[ -n "$name" && -d "$detect" && "$sstrat" == "additive" && -n "$sdir" ]] || continue
    [[ "$DRY_RUN" == "1" ]] || mkdir -p "$sdir"
    for skill in "$SKILLS_DIR"/*/; do
      [[ -d "$skill" ]] || continue
      sname="$(basename "$skill")"
      link_additive "${skill%/}" "$sdir/$sname"
    done
  done <<EOF
$(registry)
EOF
  log "sync done"
}

# ── verify (topology + integrity) ────────────────────────────────────────────
FAILS=0
check() {
  if [[ "$1" == "0" ]]; then pass_msg "$2"; else fail_msg "$2"; FAILS=$((FAILS + 1)); fi
}

cmd_verify() {
  log "verifying fabric wiring"

  [[ -d "$FABRIC_HOME" ]]; check $? "hub exists: $FABRIC_HOME"
  [[ -f "$CANONICAL" && -s "$CANONICAL" && ! -L "$CANONICAL" ]]; check $? "canonical AGENTS.md is a real, non-empty file"

  local name detect instr istrat sdir sstrat cli note state
  local fanout_dirs=""
  while IFS='|' read -r name detect instr istrat sdir sstrat cli note; do
    [[ -n "$name" && -d "$detect" ]] || continue
    [[ "$sstrat" == "additive" && -n "$sdir" ]] && fanout_dirs="$fanout_dirs $sdir"
    case "$istrat" in
      manual)
        warn "$name: instructions are manual — $note"
        ;;
      symlink)
        state="$(instr_state "$instr" "$istrat")"
        if [[ "$state" == "wired" ]]; then
          pass_msg "$name: $instr -> canonical"
        else
          fail_msg "$name: $instr is $state (run: fabric sync)"
          FAILS=$((FAILS + 1))
        fi
        ;;
    esac
  done <<EOF
$(registry)
EOF

  # Broken symlinks in hub + fanout dirs
  local broken=0 link_path
  while IFS= read -r link_path; do
    [[ -n "$link_path" ]] || continue
    broken=$((broken + 1)); fail_msg "broken symlink: $link_path"; FAILS=$((FAILS + 1))
  done <<EOF
$(find "$SKILLS_DIR" $fanout_dirs -maxdepth 1 -type l ! -exec test -e {} \; -print 2>/dev/null)
EOF
  [[ "$broken" -eq 0 ]] && pass_msg "no broken skill symlinks"

  # Skill integrity: frontmatter present + known corruption signatures absent.
  local skill sf bad=0
  for skill in "$SKILLS_DIR"/*/; do
    [[ -d "$skill" ]] || continue
    sf="$skill/SKILL.md"
    if [[ ! -f "$sf" ]]; then
      fail_msg "missing SKILL.md: $skill"; FAILS=$((FAILS + 1)); bad=1; continue
    fi
    if ! head -5 "$sf" | grep -q '^name:'; then
      fail_msg "missing 'name:' frontmatter: $sf"; FAILS=$((FAILS + 1)); bad=1
    fi
    if grep -qE '^description: ">-"$|^## MANUAL MIGRATION REQUIRED$' "$sf"; then
      fail_msg "corrupted frontmatter / migration residue: $sf"; FAILS=$((FAILS + 1)); bad=1
    fi
  done
  [[ "$bad" -eq 0 ]] && pass_msg "all hub skills have intact frontmatter"

  echo
  if [[ "$FAILS" -eq 0 ]]; then
    printf '%sAll fabric checks passed.%s\n' "$GREEN" "$NC"
    return 0
  fi
  printf '%s%d fabric check(s) failed.%s\n' "$RED" "$FAILS" "$NC"
  return 1
}

# ── doctor (effective-loading probes) ────────────────────────────────────────
cmd_doctor() {
  log "probing effective instruction loading (beyond symlink topology)"
  local canon_resolved
  canon_resolved="$(readlink -f "$CANONICAL" 2>/dev/null || echo '')"
  [[ -n "$canon_resolved" && -s "$canon_resolved" ]]; check $? "canonical resolves and is non-empty"

  local name detect instr istrat sdir sstrat cli note resolved
  while IFS='|' read -r name detect instr istrat sdir sstrat cli note; do
    [[ -n "$name" && -d "$detect" ]] || continue

    # CLI presence (informational — a harness may be config-dir only)
    if [[ -n "$cli" ]]; then
      if command -v "$cli" >/dev/null 2>&1; then
        pass_msg "$name: CLI '$cli' found on PATH"
      else
        warn "$name: CLI '$cli' not on PATH (config dir exists; probe skipped)"
      fi
    fi

    case "$istrat" in
      manual)
        info_msg "$name: MANUAL/unverifiable — $note"
        ;;
      symlink)
        if [[ ! -e "$instr" ]]; then
          fail_msg "$name: $instr missing — harness loads nothing"; FAILS=$((FAILS + 1))
        else
          resolved="$(readlink -f "$instr" 2>/dev/null || echo '')"
          if [[ -n "$resolved" && "$resolved" == "$canon_resolved" ]]; then
            pass_msg "$name: instruction path resolves to canonical content"
          elif [[ -f "$instr" ]] && grep -q '^@' "$instr" && grep -q "$(basename "$CANONICAL")" "$instr"; then
            pass_msg "$name: overlay file imports canonical via @-import"
          elif [[ -f "$instr" ]] && cmp -s "$instr" "$CANONICAL"; then
            warn "$name: $instr is a byte-identical COPY (works today, will drift — prefer symlink)"
          else
            fail_msg "$name: $instr does NOT resolve to canonical (stale or divergent content)"
            FAILS=$((FAILS + 1))
          fi
        fi
        ;;
    esac

    # Skills: every fanned-out entry must resolve
    if [[ "$sstrat" == "additive" && -n "$sdir" && -d "$sdir" ]]; then
      local broken
      broken="$(find "$sdir" -maxdepth 1 -type l ! -exec test -e {} \; -print 2>/dev/null | wc -l | tr -d ' ')"
      if [[ "$broken" == "0" ]]; then
        pass_msg "$name: all skill links in $sdir resolve"
      else
        fail_msg "$name: $broken broken skill link(s) in $sdir"; FAILS=$((FAILS + 1))
      fi
    fi
  done <<EOF
$(registry)
EOF

  echo
  log "deeper per-tool diagnostics (run manually; not invoked automatically):"
  echo "  claude /doctor · codex doctor · grok (inspect) · gemini (about) · opencode mcp · hermes doctor"
  echo
  if [[ "$FAILS" -eq 0 ]]; then
    printf '%sAll doctor probes passed.%s\n' "$GREEN" "$NC"
    return 0
  fi
  printf '%s%d doctor probe(s) failed.%s\n' "$RED" "$FAILS" "$NC"
  return 1
}

# ── status ───────────────────────────────────────────────────────────────────
cmd_status() {
  local as_json=0
  [[ "${1:-}" == "--json" ]] && as_json=1

  local skills=() skill
  for skill in "$SKILLS_DIR"/*/; do
    [[ -d "$skill" ]] && skills[${#skills[@]}]="$(basename "$skill")"
  done

  if [[ "$as_json" == "0" ]]; then
    log "hub: $FABRIC_HOME"
    log "skills in hub: ${#skills[@]}"
    local name detect instr istrat sdir sstrat cli note state
    while IFS='|' read -r name detect instr istrat sdir sstrat cli note; do
      [[ -n "$name" ]] || continue
      if [[ ! -d "$detect" ]]; then
        printf '  %-10s not detected\n' "$name"
        continue
      fi
      state="$(instr_state "$instr" "$istrat")"
      printf '  %-10s instructions: %-8s [%s]' "$name" "$istrat" "$state"
      [[ "$sstrat" == "additive" ]] && printf '  skills: %s' "$sdir"
      printf '\n'
    done <<EOF
$(registry)
EOF
    return 0
  fi

  # JSON mode
  printf '{'
  printf '"fabric_home":"%s",' "$(json_escape "$FABRIC_HOME")"
  printf '"canonical":"%s",' "$(json_escape "$CANONICAL")"
  printf '"skill_count":%d,' "${#skills[@]}"
  printf '"skills":['
  local first=1 s
  for s in ${skills[@]+"${skills[@]}"}; do
    [[ "$first" == "1" ]] || printf ','
    printf '"%s"' "$(json_escape "$s")"
    first=0
  done
  printf '],'
  printf '"harnesses":['
  first=1
  local name detect instr istrat sdir sstrat cli note state detected linked
  while IFS='|' read -r name detect instr istrat sdir sstrat cli note; do
    [[ -n "$name" ]] || continue
    [[ "$first" == "1" ]] || printf ','
    first=0
    if [[ -d "$detect" ]]; then detected=true; else detected=false; fi
    state="$(instr_state "$instr" "$istrat")"
    [[ "$detected" == "false" ]] && state="not-detected"
    printf '{"name":"%s","detected":%s,' "$(json_escape "$name")" "$detected"
    printf '"instructions":{"path":"%s","strategy":"%s","state":"%s"},' \
      "$(json_escape "$instr")" "$(json_escape "$istrat")" "$(json_escape "$state")"
    linked=0
    if [[ "$sstrat" == "additive" && -n "$sdir" && -d "$sdir" ]]; then
      for s in ${skills[@]+"${skills[@]}"}; do
        [[ -e "$sdir/$s" ]] && linked=$((linked + 1))
      done
    fi
    printf '"skills":{"path":"%s","strategy":"%s","linked":%d},' \
      "$(json_escape "$sdir")" "$(json_escape "$sstrat")" "$linked"
    printf '"note":"%s"}' "$(json_escape "$note")"
  done <<EOF
$(registry)
EOF
  printf ']}'
  printf '\n'
}

# ── add-skill / adopt ────────────────────────────────────────────────────────
cmd_add_skill() {
  local name="${1:-}"
  [[ -n "$name" ]] || { fail_msg "usage: fabric add-skill <name>"; exit 1; }
  local dir="$SKILLS_DIR/$name"
  [[ -e "$dir" ]] && { fail_msg "skill already exists: $dir"; exit 1; }
  mkdir -p "$dir"
  cat > "$dir/SKILL.md" <<EOF
---
name: $name
description: >-
  TODO: one paragraph describing when an agent should use this skill. Include
  concrete trigger phrases the user would actually say.
---

# $name

TODO: instructions for the agent.
EOF
  ok "created $dir/SKILL.md"
  cmd_sync
  log "edit $dir/SKILL.md — every agent sees changes instantly (it's one file)"
}

cmd_adopt() {
  local src="${1:-}"
  [[ -n "$src" && -d "$src" ]] || { fail_msg "usage: fabric adopt <existing-skill-dir>"; exit 1; }
  [[ -L "$src" ]] && { fail_msg "$src is already a symlink — nothing to adopt"; exit 1; }
  [[ -f "$src/SKILL.md" ]] || { fail_msg "$src has no SKILL.md"; exit 1; }
  local name dest
  name="$(basename "$src")"
  dest="$SKILLS_DIR/$name"
  [[ -e "$dest" ]] && { fail_msg "hub already has a skill named $name"; exit 1; }
  mv "$src" "$dest"
  ln -s "$dest" "$src"
  ok "adopted $name into hub; original location now symlinks to it"
  cmd_sync
}

# ── dispatch ─────────────────────────────────────────────────────────────────
cmd="${1:-help}"
case "$cmd" in
  sync)      shift; cmd_sync "$@" ;;
  verify)    cmd_verify ;;
  doctor)    cmd_doctor ;;
  status)    shift 2>/dev/null || true; cmd_status "${1:-}" ;;
  add-skill) shift; cmd_add_skill "${1:-}" ;;
  adopt)     shift; cmd_adopt "${1:-}" ;;
  help|--help|-h) usage ;;
  *) fail_msg "unknown command: $cmd (try: fabric help)"; exit 1 ;;
esac
